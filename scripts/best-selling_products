-- Purpose:
-- Calculate the products with more units sold than the mean of total
-- products sold.
--
-- Exercise:
-- Practice using subqueries to retrieve the product name and total units
-- sold from the best-selling products compared to the average.


SELECT ProductID,
       (
	    -- Subquerie used to bring the product name.
		SELECT ProductName
		FROM Products
		WHERE ProductID = OrderDetails.ProductID) AS ProductName,
	   Quantity	AS TotalQuantity  
FROM OrderDetails
WHERE Quantity > (
				 -- Subquerie used to calculate the mean of products sold.
				 SELECT AVG(Quantity) 
				 FROM OrderDetails
				 )
GROUP BY ProductID
ORDER BY TotalQuantity DESC
